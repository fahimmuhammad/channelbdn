Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /channelbdn/

    # Block direct access to includes
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^admin/includes/ - [F,L]

    # Block access to sensitive files
    RewriteRule ^config\.php - [F,L]
    RewriteRule ^db_setup\.sql - [F,L]
    RewriteRule ^db_migrate\.php - [F,L]
    RewriteRule ^db_roles_migrate\.php - [F,L]
    RewriteRule ^db_seed_extra\.php - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

<FilesMatch "\.(sql|log|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
